<?xml version="1.0"?>
<!-- Complexity gate. Run: vendor/bin/phpmd src text configs/phpmd.xml
     Pairs with REFERENCE.md Complexity Limits (thresholds match the doc maximums). -->
<ruleset name="quality-gate"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>Complexity limits for the quality gate.</description>

    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="11"/> <!-- doc maximum 10 -->
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/NPathComplexity"/>
    <rule ref="rulesets/codesize.xml/ExcessiveMethodLength">
        <properties>
            <property name="minimum" value="51"/>     <!-- doc maximum 50 lines -->
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveClassLength">
        <properties>
            <property name="minimum" value="501"/>    <!-- doc maximum 500 lines -->
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveParameterList">
        <properties>
            <property name="minimum" value="7"/>      <!-- doc maximum 6 -->
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessivePublicCount">
        <properties>
            <property name="minimum" value="16"/>     <!-- doc maximum 15 -->
        </properties>
    </rule>

    <!-- Catch a few high-value design/clean-code smells. -->
    <rule ref="rulesets/cleancode.xml/ErrorControlOperator"/> <!-- MUST NOT: '@' suppression -->
    <rule ref="rulesets/design.xml/EvalExpression"/>
    <rule ref="rulesets/design.xml/ExitExpression"/>
</ruleset>
