<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!-- Pairs with JAVA-CODE-QUALITY-GATE.md Complexity Limits.
     Run: ./mvnw checkstyle:check  -->
<module name="Checker">
  <property name="severity" value="error"/>

  <module name="FileLength">
    <property name="max" value="600"/>   <!-- doc maximum -->
  </module>

  <module name="TreeWalker">
    <module name="CyclomaticComplexity">
      <property name="max" value="10"/>  <!-- doc maximum -->
    </module>
    <module name="MethodLength">
      <property name="max" value="50"/>  <!-- doc maximum -->
      <property name="countEmpty" value="false"/>
    </module>
    <module name="ParameterNumber">
      <property name="max" value="6"/>   <!-- doc maximum -->
    </module>
    <module name="NestedIfDepth">
      <property name="max" value="3"/>   <!-- doc maximum -->
    </module>
    <module name="NestedForDepth">
      <property name="max" value="3"/>
    </module>
    <module name="NestedTryDepth">
      <property name="max" value="3"/>
    </module>

    <!-- MUST NOT: wildcard imports, magic style drift -->
    <module name="AvoidStarImport"/>
    <module name="UnusedImports"/>
    <module name="EmptyCatchBlock"/>   <!-- MUST NOT: swallowed exceptions -->
  </module>
</module>
