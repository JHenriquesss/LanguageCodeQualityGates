# Pairs with CSharp_CODE_QUALITY_GATE.md sections 6-7. Verify: dotnet format --verify-no-changes
# Roslyn analyzer severities. Async/disposal/security warnings are errors (MUST NOT items).
root = true

[*.cs]
indent_style = space
indent_size = 4
charset = utf-8
insert_final_newline = true
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = inside_namespace:warning

# Async / concurrency (MUST NOT: async void, blocking on async)
dotnet_diagnostic.CS4014.severity = error   # unawaited task
dotnet_diagnostic.CA2007.severity = none    # ConfigureAwait: enable per-project policy
dotnet_diagnostic.CA1849.severity = warning # call async methods in async context

# Resource/disposal
dotnet_diagnostic.CA2000.severity = warning # dispose before losing scope
dotnet_diagnostic.CA1063.severity = warning # implement Dispose correctly

# Security
dotnet_diagnostic.CA2100.severity = warning # SQL injection
dotnet_diagnostic.CA5350.severity = warning # weak crypto
dotnet_diagnostic.CA5351.severity = error   # broken crypto (MD5/SHA1)

# Nullable
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8625.severity = error

[*.{json,yml,yaml,csproj,props,targets}]
indent_style = space
indent_size = 2
